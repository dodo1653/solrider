{
  "name": "notes-app",
  "productName": "Notes app",
  "author": "Your Name",
  "description": "A minimal dark notes desktop app",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "framer-motion": "^11.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.notes.app",
    "productName": "Notes app",
    "directories": {
      "output": "dist-output"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/logo.png"
    },
    "portable": {
      "artifactName": "NotesApp.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "artifactName": "NotesApp-Setup.exe"
    }
  }
}